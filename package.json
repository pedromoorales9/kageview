{
  "name": "kageview",
  "version": "1.0.0",
  "description": "KageView — Anime Desktop Streaming App",
  "main": "dist/main/main.js",
  "author": "Sh4Dow",
  "license": "MIT",
  "scripts": {
    "start": "concurrently \"npm run start:renderer\" \"wait-on http://localhost:1212 && npm run build:preload && npm run build:main:dev && npm run start:main\"",
    "start:main": "cross-env NODE_ENV=development ELECTRON_IS_DEV=1 electron ./dist/main/main.js",
    "start:renderer": "cross-env NODE_ENV=development webpack serve --config .erb/configs/webpack.config.renderer.dev.ts",
    "build": "npm run build:preload && npm run build:main && npm run build:renderer",
    "build:preload": "webpack --config .erb/configs/webpack.config.preload.ts",
    "build:main": "cross-env NODE_ENV=production webpack --config .erb/configs/webpack.config.main.prod.ts",
    "build:main:dev": "cross-env NODE_ENV=development webpack --config .erb/configs/webpack.config.main.prod.ts",
    "build:renderer": "cross-env NODE_ENV=production webpack --config .erb/configs/webpack.config.renderer.prod.ts",
    "package": "npm run build && electron-builder build --publish never",
    "dist:win": "npm run build && electron-builder build --win --publish never",
    "dist:linux": "npm run build && electron-builder build --linux --publish never",
    "lint": "eslint src/ --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "com.sh4dow.kageview",
    "productName": "KageView",
    "directories": {
      "output": "release/build"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Video"
    },
    "protocols": [
      {
        "name": "KageView",
        "schemes": [
          "kageview"
        ]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "pedromoorales9",
      "repo": "KageView"
    }
  },
  "dependencies": {
    "axios": "^1.6.2",
    "discord-rpc": "^4.0.1",
    "electron-log": "^5.4.3",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7",
    "fastest-levenshtein": "^1.0.16",
    "hls.js": "^1.5.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "css-loader": "^6.8.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "html-webpack-plugin": "^5.5.4",
    "mini-css-extract-plugin": "^2.7.6",
    "postcss": "^8.4.32",
    "postcss-loader": "^7.3.3",
    "style-loader": "^3.3.3",
    "tailwindcss": "^3.3.6",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2",
    "wait-on": "^7.2.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.2",
    "webpack-merge": "^5.10.0"
  }
}
